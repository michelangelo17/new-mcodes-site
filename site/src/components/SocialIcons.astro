---
// One source of truth for the social/contact icons. Used by Header and
// Footer so updates land in one place. Add or remove a link here, both
// surfaces follow.

interface SocialLink {
	href: string;
	label: string;
	icon: 'github' | 'devto' | 'linkedin' | 'rss' | 'mail';
}

const links: SocialLink[] = [
	{ href: 'https://github.com/michelangelo17', label: 'GitHub', icon: 'github' },
	{ href: 'https://dev.to/michelangelo17', label: 'dev.to', icon: 'devto' },
	{
		href: 'https://www.linkedin.com/in/michelangelo-markus/',
		label: 'LinkedIn',
		icon: 'linkedin',
	},
	{ href: '/rss.xml', label: 'RSS', icon: 'rss' },
	{ href: 'mailto:m@michelangelo.codes', label: 'Email', icon: 'mail' },
];
---

<ul class="social-icons">
	{
		links.map(({ href, label, icon }) => (
			<li>
				<a
					href={href}
					aria-label={label}
					{...icon === 'mail' || icon === 'rss' ? {} : { target: '_blank', rel: 'me noopener' }}
				>
					<span class="sr-only">{label}</span>
					{icon === 'github' && (
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1-.02-1.95-3.2.69-3.87-1.54-3.87-1.54-.52-1.34-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.9-.39.99 0 1.98.13 2.9.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.73.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.26 5.68.41.35.78 1.04.78 2.1 0 1.52-.01 2.74-.01 3.11 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
							/>
						</svg>
					)}
					{icon === 'devto' && (
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								fill="currentColor"
								d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.01 2.19.02 2.19.37-.02c.27-.02.4-.07.55-.21.18-.16.18-.18.21-2.21.02-1.95 0-2.05-.18-2.21zM0 4.94v14.12h24V4.94H0zm8.56 9.27c-.32.46-1.01.78-1.74.78H4.93V8.96h1.96c.78 0 1.41.21 1.83.61.36.34.46.65.46 1.43 0 .77-.07 1.07-.32 1.39.16.14.32.45.32.81 0 .53-.06.84-.62 1.01zm5.66-4.31H12.4v1.42h1.13v1.28H12.4v1.42h1.82v1.28h-1.96c-1.41-.04-1.46-.06-1.65-.4-.06-.13-.07-1-.06-3 .02-2.66.03-2.83.18-3.03.18-.27.71-.41 1.95-.42h1.54v1.45zm5.51 4.62c-.5 1.39-1.71 1.6-2.5.39-.16-.27-.6-1.6-1.05-3.4-.62-2.39-.71-2.85-.62-3.06.17-.4.71-.66 1.17-.55.62.15.79.59 1.5 3.43.36 1.43.69 2.6.72 2.6.03 0 .36-1.17.72-2.6.71-2.84.88-3.28 1.5-3.43.46-.11 1.01.15 1.17.55.09.21 0 .68-.62 3.06-.46 1.81-.89 3.14-1.05 3.41z"
							/>
						</svg>
					)}
					{icon === 'linkedin' && (
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								fill="currentColor"
								d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
							/>
						</svg>
					)}
					{icon === 'rss' && (
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								fill="currentColor"
								d="M4 4v3a13 13 0 0 1 13 13h3A16 16 0 0 0 4 4zm0 7v3a6 6 0 0 1 6 6h3a9 9 0 0 0-9-9zm1.5 6a1.75 1.75 0 1 0 0 3.5 1.75 1.75 0 0 0 0-3.5z"
							/>
						</svg>
					)}
					{icon === 'mail' && (
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
							<path
								fill="currentColor"
								d="M3 5.5h18a1.5 1.5 0 0 1 1.5 1.5v10a1.5 1.5 0 0 1-1.5 1.5H3A1.5 1.5 0 0 1 1.5 17V7A1.5 1.5 0 0 1 3 5.5zm9 7.05L3.84 7.5h16.32L12 12.55zM3 17h18V9.16l-8.55 5.3a.9.9 0 0 1-.9 0L3 9.16V17z"
							/>
						</svg>
					)}
				</a>
			</li>
		))
	}
</ul>

<style>
	.social-icons {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 0.75em;
	}
	.social-icons a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--text-muted);
		border-radius: 6px;
		border-bottom: none;
		transition: color 120ms ease, background 120ms ease;
	}
	.social-icons a:hover {
		color: var(--accent);
		background: var(--code-bg);
		border-bottom: none;
	}
</style>
