# Local environment for OpenTofu + the deploy script. Copy this to .env and
# fill in real values; .env is gitignored, .env.example stays committed.
#
# Usage:
#   - scripts/deploy-site.sh auto-loads this (sources ../.env if present).
#   - For tofu, source it before running:   set -a; source ../.env; set +a; tofu apply
#   - For the server, `npm start` auto-reads root .env via --env-file-if-exists.
#
# AWS_* below is intentionally the SCALEWAY keys (the S3 state backend uses
# those names against Scaleway's endpoint). To run real-AWS CLI commands
# locally (e.g. CloudFront invalidation), override them inline:
#   AWS_ACCESS_KEY_ID=$TF_VAR_aws_access_key \
#   AWS_SECRET_ACCESS_KEY=$TF_VAR_aws_secret_key \
#     aws cloudfront create-invalidation ...

# Scaleway: providers, image registry, S3 state backend
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=
SCW_DEFAULT_ORGANIZATION_ID=

# Tofu S3 state backend — Scaleway keys under AWS_* names
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Real AWS (for the aws provider in tofu — Route 53, ACM, CloudFront)
TF_VAR_aws_access_key=
TF_VAR_aws_secret_key=
TF_VAR_route53_zone_id=Z0653618XN9NUL9KXEU8

# Site deploy (scripts/deploy-site.sh)
SCW_BUCKET=mcodes-site
SCW_S3_ENDPOINT=https://s3.fr-par.scw.cloud

# Server (optional — defaults are fine)
# PORT=8080
# POSTS_DIR=../site/src/content/posts
# FINDINGS_ENABLED=false
