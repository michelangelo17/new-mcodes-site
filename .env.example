# Copy to .env (gitignored). AWS auth is SSO locally / OIDC in CI — no AWS keys.
# See SETUP.md for the tofu init backend-config flags.

# Scaleway: providers, registry, state backend, site sync
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=
SCW_DEFAULT_ORGANIZATION_ID=

# Route 53 zone (passed to tofu)
TF_VAR_route53_zone_id=Z0653618XN9NUL9KXEU8

# Scaleway IAM application ID of the deploy key bearer (for the bucket policy)
TF_VAR_deploy_application_id=

# Site deploy (scripts/deploy-site.sh)
SCW_BUCKET=mcodes-site
SCW_S3_ENDPOINT=https://s3.fr-par.scw.cloud

# Server (optional)
# PORT=8080
# POSTS_DIR=../site/src/content/posts
# FINDINGS_ENABLED=false
