---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'posts'>['data'];

const { title, date, tags, summary, canonicalUrl } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={summary} />
		{/* Point search engines at the canonical home when cross-posted. */}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<p class="date">
						<FormattedDate date={date} />
					</p>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<ul class="tags">
								{tags.map((t) => (
									<li>#{t}</li>
								))}
							</ul>
						)
					}
					{
						canonicalUrl && (
							<p class="canonical-note">
								Originally published at <a href={canonicalUrl}>{canonicalUrl}</a>.
							</p>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
			<Comments />
		</main>
		<Footer />

		<style>
			.post-header {
				margin-bottom: 2.5rem;
			}
			.post-header h1 {
				margin: 0 0 0.75rem 0;
				font-size: 2.1rem;
				line-height: 1.2;
			}
			.date {
				margin: 0 0 0.5rem 0;
				color: var(--text-faint);
				font-size: 0.9rem;
			}
			.tags {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				font-family: var(--font-mono), ui-monospace, monospace;
				font-size: 0.78rem;
				color: var(--text-muted);
			}
			.tags li {
				margin: 0;
			}
			.canonical-note {
				margin-top: 1rem;
				font-size: 0.9rem;
				color: var(--text-muted);
			}
			.prose {
				border-top: 1px solid var(--border);
				padding-top: 2rem;
			}
			.prose :global(p) {
				margin: 0 0 1.2em 0;
			}
			.prose :global(h2) {
				margin-top: 2.25em;
			}
			.prose :global(h3) {
				margin-top: 1.75em;
			}
			.prose :global(a) {
				border-bottom: 1px solid var(--border);
			}
			.prose :global(a:hover) {
				border-bottom-color: currentColor;
			}
		</style>
	</body>
</html>
