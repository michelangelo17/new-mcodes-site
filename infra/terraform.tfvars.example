# Copy to terraform.tfvars (gitignored) or pass via -var / TF_VAR_*.
# Secrets (aws_*, and the SCW_*/AWS_* env for providers + backend) should come
# from CI secrets or your shell, not this file.

region             = "fr-par"
site_bucket_name   = "mcodes-site"
site_domain        = "michelangelo.codes"
registry_namespace = "mcodes"
mcp_domain         = "mcp.michelangelo.codes"
findings_enabled   = false

# Set by CI per build:
# container_image = "rg.fr-par.scw.cloud/mcodes/mcodes-mcp:<git-sha>"

# From your AWS account / Route 53:
# route53_zone_id = "Z0123456789ABCDEFG"
# aws_access_key  = "AKIA..."        # prefer TF_VAR_aws_access_key in CI
# aws_secret_key  = "..."            # prefer TF_VAR_aws_secret_key in CI
